coldPath   = $SPLUNK_DB/{{ idx.name }}/colddb
thawedPath = $SPLUNK_DB/{{ idx.name }}/thaweddb
maxDataSizeMB = {{ idx.maxDataSizeMB }}
frozenTimePeriodInSecs = {{ idx.frozenTimePeriodInSecs }}

{% endfor %}
